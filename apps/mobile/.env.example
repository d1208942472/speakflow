# SpeakFlow Mobile — Environment Variables (Expo)
# Copy this file to .env.local and fill in your values
# All Expo public env vars must be prefixed with EXPO_PUBLIC_

# API backend URL (required)
EXPO_PUBLIC_API_URL=http://localhost:8000   # local dev
# EXPO_PUBLIC_API_URL=https://speakflow-api.onrender.com  # production (Render)

# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key   # anon/public key — safe to expose in client

# RevenueCat (required for subscriptions)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_your_ios_key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_your_android_key
