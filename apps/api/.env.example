# SpeakFlow API — Environment Variables
# Copy this file to .env and fill in your values

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # NOT the anon key — service role has admin access

# NVIDIA (required)
# You can use a single key for both Riva ASR and NIM, or set them separately
NVIDIA_API_KEY=nvapi-your-key-here
# NVIDIA_NIM_API_KEY=nvapi-separate-nim-key  # optional override for NIM only

# RevenueCat webhook verification (optional)
# If absent, signature verification is skipped (not recommended for production)
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# Admin secret for protected endpoints like /notifications/send-reminders (optional)
# If absent, admin endpoints are accessible without auth (not recommended for production)
ADMIN_SECRET=your-admin-secret-here
