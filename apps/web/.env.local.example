# SpeakFlow Web — Environment Variables
# Copy to .env.local for local development

# Supabase (from supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Server-only, for Stripe webhook

# Stripe (from stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_ANNUAL_PRICE_ID=price_...   # Create in Stripe Dashboard: $79.99/yr recurring
STRIPE_WEBHOOK_SECRET=whsec_...    # Stripe Dashboard → Webhooks → speakflow-lake.vercel.app/api/webhooks/stripe

# Site URL (used for Stripe redirect and OG tags)
NEXT_PUBLIC_SITE_URL=https://speakflow-lake.vercel.app
