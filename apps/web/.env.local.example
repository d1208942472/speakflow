# SpeakFlow Web — Environment Variables
# Copy to .env.local for local development

# Supabase (from supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Server-only, for Stripe webhook

# Stripe (from stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_ANNUAL_PRICE_ID=price_...   # Create in Stripe Dashboard: $79.99/yr recurring
STRIPE_WEBHOOK_SECRET=whsec_...    # Stripe Dashboard → Webhooks → https://api.speakmeteor.win/webhooks/stripe

# Site URL (used for Stripe redirect and OG tags)
NEXT_PUBLIC_SITE_URL=https://speakmeteor.win
NEXT_PUBLIC_API_URL=https://api.speakmeteor.win
NEXT_PUBLIC_CANONICAL_SITE_URL=https://speakmeteor.win
NEXT_PUBLIC_WEB_CHECKOUT_ENABLED=false
NEXT_PUBLIC_CONTACT_EMAIL=hello@speakmeteor.win
NEXT_PUBLIC_SUPPORT_EMAIL=support@speakmeteor.win
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@speakmeteor.win
NEXT_PUBLIC_LEGAL_EMAIL=legal@speakmeteor.win
